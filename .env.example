# Cumulative goal tally storage — Vercel KV (Upstash Redis).
# These are injected automatically when you connect a KV/Upstash store to the
# Vercel project (Storage tab → Create/Connect). For local dev, copy this file to
# .env and paste the values from the Upstash dashboard (".env" tab / REST API).
# Without them the tally falls back to an in-memory counter that resets per run.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternatively, if you provision Upstash directly (outside the Vercel marketplace):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
